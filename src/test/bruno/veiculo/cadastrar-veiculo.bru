meta {
  name: Cadastrar Veiculo
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/veiculo
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

headers {
  Content-Type: application/json
}

