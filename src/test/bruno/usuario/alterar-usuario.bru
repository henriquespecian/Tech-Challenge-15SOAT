meta {
  name: Alterar Usuario
  type: http
  seq: 3
}

put {
  url: {{baseUrl}}/usuario/:id
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

headers {
  Content-Type: application/json
}

params:path {
  id:
}

body:json {
  {
    "nome": "João Silva Atualizado",
    "email": "joao@email.com",
    "perfil": "MECANICO"
  }
}
